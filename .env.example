# =============================================================================
# Hostel Pro — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# Database
DATABASE_URL=postgresql://db_user1:Raju987.@localhost:5432/hostel_pro

# Better Auth
BETTER_AUTH_SECRET=          # Generate: openssl rand -hex 32
BETTER_AUTH_URL=http://localhost:3000

# Encryption
ENCRYPTION_KEY=              # Generate: openssl rand -hex 32
HASH_SALT=                   # Generate: openssl rand -hex 16

# Razorpay (payment gateway)
RAZORPAY_MODE=mock           # mock | live
RAZORPAY_KEY_ID=             # Required when RAZORPAY_MODE=live
RAZORPAY_KEY_SECRET=         # Required when RAZORPAY_MODE=live
RAZORPAY_WEBHOOK_SECRET=     # Required when RAZORPAY_MODE=live

# SMS (Twilio — primary)
SMS_MODE=mock                # mock | live
TWILIO_ACCOUNT_SID=          # Required when SMS_MODE=live
TWILIO_AUTH_TOKEN=           # Required when SMS_MODE=live
TWILIO_PHONE_NUMBER=         # Required when SMS_MODE=live

# SMS (MSG91 — fallback)
MSG91_AUTH_KEY=               # Required when SMS_MODE=live
MSG91_TEMPLATE_ID=            # Required when SMS_MODE=live

# Notifications
NOTIFICATION_MODE=mock       # mock | live
EMAIL_PROVIDER=console       # console | resend | sendgrid | ses
EMAIL_FROM=noreply@hostelpro.local
RESEND_API_KEY=              # Required when EMAIL_PROVIDER=resend
SENDGRID_API_KEY=            # Required when EMAIL_PROVIDER=sendgrid
WHATSAPP_MODE=mock           # mock | live

# Storage
UPLOAD_DIR=./uploads

# Security
SIGNED_URL_SECRET=           # Generate: openssl rand -hex 32
CRON_SECRET=                 # Generate: openssl rand -hex 32
